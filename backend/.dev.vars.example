# Copy to `backend/.dev.vars` for local development.
# Do not commit the real .dev.vars file.
APP_NAME=scarabev-backend
APP_ENV=dev
LOG_LEVEL=debug
OBS_SAMPLE_RATE=1
# Optional: remote error sink (future integration)
ERROR_SINK_DSN=
SESSION_COOKIE_NAME=scarabev_session
CSRF_COOKIE_NAME=scarabev_csrf
SESSION_TTL_SECONDS=28800
SESSION_ROTATION_SECONDS=1800
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_PER_IP=30
AUTH_RATE_LIMIT_PER_USER=15
ADMIN_RATE_LIMIT_WINDOW_SECONDS=60
ADMIN_RATE_LIMIT_PER_IP=240
ADMIN_RATE_LIMIT_PER_USER=120
