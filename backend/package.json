{
  "name": "scarabev-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "test": "npm run test:build && node .tmp-test/index.test.js",
    "test:build": "tsc -p tsconfig.test.json",
    "typecheck": "tsc --noEmit",
    "security:check": "npm audit --omit=dev --audit-level=high",
    "deps:outdated": "npm outdated",
    "block7:export-inventory": "node ./scripts/data-migration/export-inventory.mjs",
    "block7:migrate:dry-run": "node ./scripts/data-migration/migrate-scarabs.mjs",
    "block7:migrate:apply": "node ./scripts/data-migration/migrate-scarabs.mjs --apply",
    "block7:parity": "node ./scripts/data-migration/parity-check.mjs",
    "deploy:staging": "wrangler deploy --config wrangler.staging.toml",
    "deploy:production": "wrangler deploy --config wrangler.production.toml"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.0",
    "@types/node": "^25.5.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.12.0"
  }
}
